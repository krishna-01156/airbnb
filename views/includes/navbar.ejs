<style>
    .search-btn {
        color: #fff;
        background-color: #ff385c;
        border-radius: 999px;
        padding: 0.5rem 1.2rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        box-shadow: none;
        transition: background 0.2s ease;
    }

    .search-btn:hover {
        background-color: #e03150;
        color: #fff;
    }

    .search-btn i {
        margin-right: 0.5rem;
    }

    .search-inp {
        border-radius: 999px;
        padding: 0.5rem 1.5rem;
        border: 1px solid #ddd;
        font-size: 0.95rem;
        width: 250px;
        box-shadow: none;
    }

    /* Dropdown style */
    .dropdown-menu-custom {
        border-radius: 12px;
        border: none;
        padding: 0.5rem 0;
        min-width: 200px;
        animation: slideDown 0.3s ease;
    }

    .dropdown-item-custom {
        padding: 1rem 1.5rem;
        font-size: 0.95rem;
        color: #000;
        display: flex;
        align-items: center;
        gap: 0.7rem;
    }

    .dropdown-item-custom:hover {
        background-color: #f7f7f7;
        color: #000;
    }

    .profile-circle {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        background: #ff385c;
        color: #fff;
        font-weight: 600;
        font-size: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hamburger-circle {
        width: 35px;
        height: 35px;
        border: 1px solid #ddd;
        border-radius: 50%;
        background: #fff;
        display: flex;
        font-size: 16px;
        cursor: pointer;
        align-items: center;
        justify-content: center;
    }

    .dropdown-toggle::after {
        display: none !important;
    }

    /* Slide down animation */
    @keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Small screens */
    @media (max-width: 576px) {
        .search-inp {
            width: 100%;
            font-size: 0.85rem;
        }

        .search-btn {
            display: none;
            /* hide search button in mobile */
        }

        /* Center search bar between logo & hamburger */
        .mobile-search {
            flex: 1;
            max-width: 60%;
            display: flex;
            justify-content: center;
        }

        .dropdown-menu-custom {
            width: 100vw;
            border-radius: 0;
            left: 0 !important;
            right: 0 !important;
        }

        /* Hide Explore link only on mobile */
        .nav-link.d-md-none {
            display: none !important;
        }
    }
</style>

<nav class="navbar navbar-expand-md navbar-light bg-body-light border-bottom sticky-top">
    <div class="container-fluid">
        <!-- Left: Logo -->
        <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>

        <!-- Mobile: Search bar centered -->
        <div class="mobile-search d-md-none">
            <form class="w-100" role="search" action="/listings" method="GET">
                <input class="form-control search-inp text-center" type="search"
                    placeholder="Search by location or country" name="location" />
            </form>
        </div>

        <!-- Hamburger Button -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Desktop Nav -->
        <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
            <!-- Desktop: Search Bar -->
            <form class="d-none d-md-flex my-2 my-md-0 mx-auto" role="search" action="/listings" method="GET">
                <input class="form-control me-2 search-inp" type="search" placeholder="Search by location or country"
                    name="location" />
                <button class="btn search-btn" type="submit">
                    <i class="fa-solid fa-magnifying-glass"></i>Search
                </button>
            </form>

            <!-- Right Side -->
            <div class="navbar-nav ms-auto align-items-center gap-2">
                <!-- Desktop only -->
                <a class="nav-link d-none d-md-block" href="/listings/new">Airbnb your home</a>

                <!-- Hamburger dropdown -->
                <div class="dropdown">
                    <button class="btn d-flex align-items-center justify-content-between gap-2 p-2 dropdown-toggle"
                        type="button" data-bs-toggle="dropdown" aria-expanded="false"
                        style="border: none; background: transparent;">
                        <% if (currentUser) { %>
                            <div class="profile-circle">
                                <%= currentUser.username.charAt(0).toUpperCase() %>
                            </div>
                            <% } %>
                                <div class="hamburger-circle d-flex align-items-center justify-content-center">
                                    <i class="fa-solid fa-bars"></i>
                                </div>
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end dropdown-menu-custom">
                        <!-- Airbnb home always in dropdown on mobile -->
                        <li><a class="dropdown-item dropdown-item-custom" href="/listings/new">Airbnb your home</a></li>

                        <% if (!currentUser) { %>
                            <li><a class="dropdown-item dropdown-item-custom" href="/login">Log in</a></li>
                            <li><a class="dropdown-item dropdown-item-custom" href="/signup">Sign up</a></li>
                            <% } else { %>
                                <li><a class="dropdown-item dropdown-item-custom" href="/wishlist">
                                        <i class="fa-regular fa-heart"></i> Wishlists</a>
                                </li>
                                <li>
                                    <form action="/logout" method="POST" class="d-inline">
                                        <button type="submit"
                                            class="dropdown-item dropdown-item-custom w-100 text-start">
                                            <i class="fa-solid fa-arrow-right-from-bracket"></i> Log out
                                        </button>
                                    </form>
                                </li>
                                <% } %>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</nav>